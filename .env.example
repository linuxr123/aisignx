# AISignX environment variables (copy to server/.env for Docker, or export for local runs)
#
#   cp .env.example server/.env
#   # Edit server/.env and set AISIGNX_SECRET_KEY to a long random value
#
# Generate a secret (PowerShell):
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Generate a secret (Linux/macOS):
#   openssl rand -hex 32

# Required for Docker Compose (server/docker-compose.yml)
AISIGNX_SECRET_KEY=change-me-to-a-long-random-string

# Optional overrides
AISIGNX_DB_PATH=/data/db/signage.sqlite
AISIGNX_DATABASE_URI=
UPLOAD_FOLDER=uploads
AISIGNX_LOG_DIR=logs
TRUST_PROXY_HOPS=1
