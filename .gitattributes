# Normalize line endings for cross-platform clones (Windows dev, Linux deploy).
* text=auto

*.sh text eol=lf
*.ps1 text eol=crlf
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.html text eol=lf
*.js text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.apk binary
*.exe binary
*.deb binary
*.AppImage binary
