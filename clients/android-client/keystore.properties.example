# AISignX Android release signing
#
# Copy this file to "keystore.properties" (same folder) and fill in real
# values, then build a signed release APK:
#
#   ../../build_clients_windows.ps1 -Android -Release
#   (or)  ./gradlew assembleRelease   from clients/android-client/
#
# IMPORTANT — signing identity is permanent for a fleet:
#   * Android only installs an update if it is signed with the SAME key as the
#     currently installed app. Pick ONE keystore and keep it safe forever.
#   * If you lose this keystore you can never update existing installs again —
#     you must uninstall + reinstall every device.
#   * Devices installed from a DIFFERENT build (e.g. a debug APK, or a release
#     signed with another key) cannot be updated to this one; reinstall them.
#
# keystore.properties is gitignored — never commit real keystores or passwords.

# Path to the keystore. Relative paths resolve from clients/android-client/app/.
storeFile=my-release-key.keystore
storePassword=CHANGE_ME
keyAlias=aisignx
keyPassword=CHANGE_ME

# To create a fresh keystore (only for a NEW fleet — not for updating existing
# installs signed with a different key):
#   keytool -genkeypair -v -keystore my-release-key.keystore \
#     -alias aisignx -keyalg RSA -keysize 2048 -validity 10000
